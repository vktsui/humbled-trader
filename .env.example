# Copy to .env and fill in (never commit .env)
#
# Pick ONE email backend. The sender auto-selects whichever is present,
# in this priority order: Resend -> SendGrid -> SMTP.

# Recipient (all backends)
EMAIL_TO=vktsui@gmail.com

# --- Option 1: Resend (recommended, simplest) ---
# Sign up at https://resend.com, create an API key.
# Free tier with NO domain: leave EMAIL_FROM as onboarding@resend.dev and it can
# only deliver to the email you signed up with. Add a verified domain to send
# from your own address to anyone.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# --- Option 2: SendGrid ---
# Sign up at https://sendgrid.com, verify a Single Sender (your from-address),
# create an API key. No domain needed for single-sender.
# SENDGRID_API_KEY=
# EMAIL_FROM=your_verified_sender@example.com

# --- Option 3: Gmail SMTP (needs an App Password) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_gmail_address@gmail.com
# SMTP_PASS=your_gmail_app_password
# EMAIL_FROM=your_gmail_address@gmail.com

# --- TradingView MCP install (default matches blog setup) ---
TRADINGVIEW_MCP_PATH=$HOME/tradingview-mcp/versions/v1
TV_CLI_NODE=node
CDP_PORT=9222
