{
  "name": "humbled-trader",
  "version": "1.0.0",
  "description": "Humbled Trader workflow: TradingView MCP scanners, automation, and Pine backtests",
  "type": "module",
  "private": true,
  "scripts": {
    "premarket": "python3 scripts/premarket_gappers.py",
